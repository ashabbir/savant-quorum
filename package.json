{
  "name": "savant-quorum",
  "version": "5.0.38",
  "description": "Quorum - A high-security multi-agent collaborative environment.",
  "author": "project-x",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "electron-builder install-app-deps && concurrently -k -n renderer,electron \"npm run dev:renderer\" \"npm run dev:electron -- --concurrent\"",
    "dev:renderer": "QUORUM_RENDERER_ONLY=1 vite --force --host 127.0.0.1 --port 5273 --strictPort",
    "dev:electron": "node scripts/start-electron-dev.mjs",
    "build": "tsc && vite build && electron-builder",
    "preview": "vite preview",
    "electron:dev": "vite",
    "test": "vitest run",
    "postinstall": "defaults write \"$PWD/node_modules/electron/dist/Electron.app/Contents/Info.plist\" CFBundleIdentifier com.github.Electron.Quorum && defaults write \"$PWD/node_modules/electron/dist/Electron.app/Contents/Frameworks/Electron Helper.app/Contents/Info.plist\" CFBundleIdentifier com.github.Electron.Quorum.helper && defaults write \"$PWD/node_modules/electron/dist/Electron.app/Contents/Frameworks/Electron Helper (Renderer).app/Contents/Info.plist\" CFBundleIdentifier com.github.Electron.Quorum.helper && defaults write \"$PWD/node_modules/electron/dist/Electron.app/Contents/Frameworks/Electron Helper (GPU).app/Contents/Info.plist\" CFBundleIdentifier com.github.Electron.Quorum.helper && defaults write \"$PWD/node_modules/electron/dist/Electron.app/Contents/Frameworks/Electron Helper (Plugin).app/Contents/Info.plist\" CFBundleIdentifier com.github.Electron.Quorum.helper && electron-builder install-app-deps || true"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^9.0.1",
    "@mui/material": "^9.0.1",
    "@popperjs/core": "^2.11.8",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-aspect-ratio": "^1.1.8",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-menubar": "^1.1.16",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@types/d3": "^7.4.3",
    "@types/react-syntax-highlighter": "^15.5.13",
    "better-sqlite3": "^12.10.0",
    "canvas-confetti": "^1.9.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "d3": "^7.9.0",
    "date-fns": "^2.30.0",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^1.17.0",
    "mermaid": "^11.15.0",
    "motion": "^12.40.0",
    "next-themes": "^0.4.6",
    "react": "^18.2.0",
    "react-day-picker": "8.10.1",
    "react-dnd": "^16.0.1",
    "react-dnd-html5-backend": "^16.0.1",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.77.0",
    "react-markdown": "^10.1.0",
    "react-popper": "^2.3.0",
    "react-resizable-panels": "2.1.7",
    "react-responsive-masonry": "^2.7.2",
    "react-router": "^7.17.0",
    "react-slick": "^0.31.0",
    "react-syntax-highlighter": "^16.1.1",
    "recharts": "2.15.2",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2"
  },
  "build": {
    "electronVersion": "31.0.0",
    "appId": "com.project-x.quorum",
    "productName": "Quorum",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "dist-electron/**/*",
      "dist/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "src/renderer/public",
        "to": "public",
        "filter": [
          "main.svg",
          "tray.svg",
          "trayTemplate.png",
          "trayTemplate@2x.png"
        ]
      }
    ],
    "mac": {
      "icon": "build/icon.icns",
      "category": "public.app-category.developer-tools",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "dmg": {
      "icon": "build/icon.icns"
    },
    "win": {
      "icon": "build/icon.png",
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "icon": "build/icon.png",
      "category": "Development",
      "target": [
        "AppImage",
        "deb"
      ]
    }
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.12",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/react": "^18.2.15",
    "@types/react-dom": "^18.2.7",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitejs/plugin-react-swc": "^4.3.1",
    "@vitest/coverage-v8": "^4.1.7",
    "@vitest/ui": "^4.1.7",
    "concurrently": "^8.2.0",
    "electron": "31.0.0",
    "electron-builder": "^26.8.1",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.1.12",
    "typescript": "^5.0.2",
    "vite": "^8.0.16",
    "vite-plugin-electron": "^1.0.4",
    "vite-plugin-electron-renderer": "^1.0.0",
    "vitest": "^4.1.7"
  }
}
