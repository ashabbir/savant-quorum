{
  "name": "savant-quorum",
  "version": "6.0.1",
  "description": "Quorum - A high-security multi-agent collaborative environment.",
  "author": "project-x",
  "main": "dist-electron/main.js",
  "dependencies": {
    "better-sqlite3": "^12.10.0"
  },
  "scripts": {
    "build": "tsc && vite build && electron-builder",
    "test": "vitest run"
  },
  "build": {
    "electronVersion": "31.0.0",
    "appId": "com.project-x.quorum",
    "productName": "Quorum",
    "directories": { "output": "release", "buildResources": "build" },
    "files": ["dist-electron/**/*", "dist/**/*", "package.json"],
    "extraResources": [
      { "from": "src/renderer/public", "to": "public", "filter": ["main.svg", "tray.svg", "trayTemplate.png", "trayTemplate@2x.png"] },
      { "from": "build/whisper-cache", "to": "whisper-cache" },
      { "from": "build/stsb-cache", "to": "stsb-cache" }
    ],
    "mac": { "icon": "build/icon.icns", "category": "public.app-category.developer-tools", "target": ["dmg", "zip"] },
    "dmg": { "icon": "build/icon.icns" }
  },
  "devDependencies": { "electron": "31.0.0", "electron-builder": "^26.8.1", "typescript": "^5.0.2", "vite": "^8.0.16", "vitest": "^4.1.7" }
}
