      "id": "concept_cost_aware_swarm_moderation",
      "label": "Cost-Aware Swarm Moderation",
      "file_type": "concept",
      "source_file": "src/renderer/services/chatExecutionPolicy.ts",
      "source_location": null,
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "Limits agent engagement to a maximum of two specialist agents per turn, defaulting to one or a direct response to minimize token costs and elapsed time. Activates independent reviews and adversarial cross-checks only when high-risk operations (e.g. production migrations, security audits) are detected."
    },
    {
      "id": "concept_factuality_citation_contract",
      "label": "Factuality Citation Contract",
      "file_type": "concept",
      "source_file": "src/renderer/services/citationContract.ts",
      "source_location": null,
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "Enforces strict facts-only communication by requiring every agent response to contain inline citations mapped to a verification table containing specific sources and evidence. If validation fails, Quorum automatically triggers a correction prompt or withholds the response to prevent hallucination."
    },
    {
      "id": "concept_mermaid_rendering_safety",
      "label": "Mermaid Diagram Rendering Safety",
      "file_type": "concept",
      "source_file": "src/renderer/utils/mermaidSanitizer.ts",
      "source_location": null,
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "Mermaid diagrams are rendered within React UI but can crash the application if unquoted labels contain special characters, spaces, or HTML. Sanitizing the code by quoting these labels prevents runtime parsing errors."
    },
